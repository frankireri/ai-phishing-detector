FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-this-to-a-strong-secret-key-in-production
JWT_SECRET_KEY=change-this-to-a-jwt-secret-key
DATABASE_URL=sqlite:///phishing_detector.db
# For PostgreSQL use:
# DATABASE_URL=postgresql://user:password@localhost:5432/phishing_detector
ML_MODEL_PATH=models_storage
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=60
